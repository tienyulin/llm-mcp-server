# mcp-server configuration. Copy to .env and fill in.
# Read-only query service. NOTE: docker compose does NOT strip inline
# "# comments" from .env values — keep comments on their own lines.

# -- MinIO (shared infra: llm-wiki-infra) --
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wiki-data

# -- PG + pgvector (shared infra; empty PG_DSN = MinIO scan fallback) --
PG_DSN=postgresql://wiki:wikipass@pg:5432/wiki
PG_RETRY_SECONDS=30

# -- Query-side embeddings (must match the processor's model/dim) --
# OpenAI-compatible /v1/embeddings root (empty = mock)
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# true for Gemini gemini-embedding-001
EMBEDDING_SEND_DIMENSIONS=false
MOCK_EMBEDDINGS=true
